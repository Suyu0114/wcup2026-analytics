# Copy this file to .env and fill in real values. .env is git-ignored — never commit it.

# football-data.org API (v4) — free tier includes the World Cup competition.
# Register: https://www.football-data.org/client/register
# Code reads this and sends it as the HTTP request header:  X-Auth-Token: <token>
FOOTBALL_DATA_TOKEN=your_football_data_token_here

# Supabase (Postgres) — service role key is used server-side by the ETL to write
# teams / matches / match_predictions. Project Settings -> API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# The Odds API — P3 only (odds / de-vig / line-shopping). Leave blank until then.
# https://the-odds-api.com/
ODDS_API_KEY=
