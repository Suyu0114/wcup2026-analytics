# ─── Secrets / env ──────────────────────────────────────────
# NEVER commit real credentials. .env holds the football-data token,
# Supabase service key, etc.
.env
.env.*
!.env.example

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ─── Raw third-party data (licensed; keep payloads out of git) ──
# Provenance documented in etl/data/raw/**/README.md — those stay tracked.
etl/data/raw/**/*.csv
etl/data/raw/**/*.tsv
etl/data/raw/**/*.json
etl/data/raw/**/*.parquet
etl/data/raw/**/*.xlsx

# Exception: canonical WC2026 Elo input is tracked for reproducibility
# (CC BY-SA 4.0 — redistribution allowed; attribution in the data dir's README).
!etl/data/raw/elo/elo_ratings_wc2026.csv

# ─── OS / editor ────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp

# ─── Claude Code local config (machine-specific; a shared settings.json is fine) ──
.claude/settings.local.json

# ─── Notebooks ──────────────────────────────────────────────
.ipynb_checkpoints/
