# P5 frontend env (spec §2.1). Copy to .env.local for local dev (git-ignored).
# ⚠️ SUPABASE_SERVICE_KEY is SERVER-ONLY — never prefix with NEXT_PUBLIC_ (TU11).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Display timezone for kickoff times (default Asia/Taipei). Optional.
SITE_TZ=Asia/Taipei

# Admin page (P7) — SERVER-ONLY, never prefix with NEXT_PUBLIC_.
# ADMIN_PASSWORD_HASH = sha256(password) hex. Generate (pick a NEW password):
#   node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
ADMIN_PASSWORD_HASH=
# Random 32+ byte secret used to HMAC the session cookie. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=
# Fine-grained GitHub PAT (repo Contents: read/write) to trigger the recompute workflow.
GITHUB_DISPATCH_TOKEN=
# owner/repo for the dispatch call (optional; defaults to Suyu0114/wcup2026-analytics).
GITHUB_REPO=Suyu0114/wcup2026-analytics
